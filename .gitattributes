# Line endings: normalize in repo so Windows/macOS/Linux behave predictably.
# See https://git-scm.com/docs/gitattributes

* text=auto

# Frontend + portable text (LF everywhere)
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.svg text eol=lf

# .NET / Visual Studio on Windows (common default)
*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf

# Scripts
*.sh text eol=lf
