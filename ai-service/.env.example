# Copy to ".env" in this folder. Do not commit real secrets.
# INTERNAL_TOKEN must match the ASP.NET Core setting AiClassifier:InternalToken.

INTERNAL_TOKEN=dev-internal-token

# Optional: when OPENAI_API_KEY is set, /classify uses OpenAI via LangChain; otherwise rule_v1.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
APP_MODEL_VERSION=langchain-v1
